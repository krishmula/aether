# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts
*.sh text eol=lf

# Python files
*.py text diff=python

# YAML files
*.yaml text
*.yml text

# Markdown
*.md text

# Docker
Dockerfile text
docker-compose.yml text

# Makefile
Makefile text

# Configuration
*.toml text
*.ini text
*.cfg text