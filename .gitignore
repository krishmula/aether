# Ignore files without extensions (for temporary diff output or notes)
*
!*/
!*.*
!Makefile
!Dockerfile
!README*
!LICENSE*
!CHANGELOG*
!CONTRIBUTING*
!CODE_OF_CONDUCT*
!AUTHORS
!pyproject.toml

# Ignore references and ideas folders (for the project spec sheet and proposal)
ref/
.idea/

# Ignore Python caches and bytecode
__pycache__/
**/__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# Distribution / build artifacts
dist/
build/
*.egg-info/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage reports
.coverage
htmlcov/

# Environment variables
.env

# OS-generated files
.DS_Store
Thumbs.db

# Claude / project-local files
.claude/
.opencode/
CLAUDE.md
config.yaml
config-local.yaml

# Generated benchmark outputs
benchmarks/results/*
!benchmarks/results/.gitkeep
