{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["aether"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Aether Failover & Recovery",
  "uid": "aether-failover",
  "version": 1,
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Successful Recoveries (1h)",
      "description": "Broker recovery attempts that completed successfully in the last hour.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "increase(aether_broker_recoveries_total{result=\"success\"}[1h])",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Failed Recoveries (1h)",
      "description": "Broker recovery attempts that failed in the last hour. Any non-zero value needs attention.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "increase(aether_broker_recoveries_total{result=\"failure\"}[1h])",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Subscriber Reconnects (1h)",
      "description": "Subscribers reassigned by the orchestrator during redistribution recovery in the last hour.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "increase(aether_subscriber_reconnects_total[1h])",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Recovery Duration p95 (10m)",
      "description": "95th percentile of end-to-end broker recovery time over the last 10 minutes. This is the subscriber outage window.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 30 }
            ]
          },
          "noValue": "—"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "histogram_quantile(0.95, rate(aether_recovery_duration_seconds_bucket[10m]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Recovery Duration",
      "description": "End-to-end recovery duration percentiles. p50 = typical case, p95 = worst-case subscriber outage window. Only has data after a recovery event occurs.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "histogram_quantile(0.50, rate(aether_recovery_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "histogram_quantile(0.95, rate(aether_recovery_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Recovery Attempts by Path",
      "description": "Cumulative recovery attempts split by path (replacement vs redistribution) and outcome. A step up means a recovery just completed.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false,
            "drawStyle": "line",
            "stacking": { "mode": "none" }
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "aether_broker_recoveries_total",
          "legendFormat": "{{recovery_path}} / {{result}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "logs",
      "title": "Broker Dead Events",
      "description": "Structured log entries where event_type=broker_declared_dead. Each line here represents one broker failure detected by the health monitor.",
      "datasource": { "type": "loki", "uid": "aether-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "aether-loki" },
          "expr": "{job=~\"aether/.*\",event_type=\"broker_declared_dead\"} | json",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "logs",
      "title": "Recovery Log Stream",
      "description": "All logs related to broker recovery — started, recovered, failed. Filter by recovery_id to trace a single recovery attempt end-to-end.",
      "datasource": { "type": "loki", "uid": "aether-loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "aether-loki" },
          "expr": "{job=~\"aether/.*\",event_type=~\"broker_recovery_started|broker_recovered|broker_recovery_failed\"} | json",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "logs",
      "title": "Subscriber Reconnect Events",
      "description": "Logs from subscribers that successfully reconnected to a new broker after failover.",
      "datasource": { "type": "loki", "uid": "aether-loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "aether-loki" },
          "expr": "{job=~\"aether/.*\",event_type=\"subscriber_reconnected\"} | json",
          "refId": "A"
        }
      ]
    }

  ]
}
