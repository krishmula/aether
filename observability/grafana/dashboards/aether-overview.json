{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["aether"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Aether System Overview",
  "uid": "aether-overview",
  "version": 1,
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Running Brokers",
      "description": "Number of broker containers currently in RUNNING state.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 2 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "sum(aether_component_up{component_type=\"broker\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Running Publishers",
      "description": "Number of publisher containers currently in RUNNING state.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "green",  "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "sum(aether_component_up{component_type=\"publisher\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Running Subscribers",
      "description": "Number of subscriber containers currently in RUNNING state.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "green",  "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "sum(aether_component_up{component_type=\"subscriber\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Broker Recoveries (24h)",
      "description": "Total broker recovery attempts in the last 24 hours. Any non-zero value means a broker has been restarted.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "increase(aether_broker_recoveries_total[24h])",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Message Throughput",
      "description": "Rate of messages processed across all brokers. Derived from broker /status polling — approximated, not per-message exact.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "mps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "rate(aether_messages_published_total[1m])",
          "legendFormat": "msg/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Broker Peer Counts",
      "description": "Number of peers visible in each broker's gossip mesh. In a healthy 3-broker cluster each broker should see 2 peers. Dropping to 0 indicates isolation.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          },
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "aether_broker_peer_count",
          "legendFormat": "broker {{broker_id}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Subscriber Distribution",
      "description": "Subscribers connected to each broker. Should be roughly equal across brokers. Sudden drop to 0 for a broker indicates it died; a spike on survivors indicates redistribution happened.",
      "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "aether-prometheus" },
          "expr": "aether_broker_subscriber_count",
          "legendFormat": "broker {{broker_id}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "logs",
      "title": "Recent Logs",
      "description": "Live log stream from all Aether processes. Use the search bar to filter. Try: event_type=broker_declared_dead or recovery_id=<uuid>.",
      "datasource": { "type": "loki", "uid": "aether-loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "aether-loki" },
          "expr": "{job=~\"aether/.*\"} | json",
          "refId": "A"
        }
      ]
    }

  ]
}
